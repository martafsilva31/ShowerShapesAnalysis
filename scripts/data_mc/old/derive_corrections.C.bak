///////////////////////////////////////////////////////////////////////////////
// derive_corrections.C
//
// Derives cell-energy reweighting corrections from SEPARATE data and MC
// files.  Unlike the closure test (paired truth/reco in same entry), data
// and MC are processed independently and corrections are derived from
// population statistics per cell, per eta bin.
//
// METHOD 1 — Flat shift per cell (CalCoef approach, §5.1):
//   shift_k = <f_data>_k - <f_MC>_k
//   Stored per cell k, per eta bin, in TH2D (phi x eta layout).
//
// METHOD 2 — Mean+RMS rescaling per cell (§5.2 adapted):
//   f_corr_k = (rms_data_k / rms_MC_k) * (f_MC_k - mean_MC_k) + mean_data_k
//   Requires population statistics only — no event-level matching.
//
// Selection: note §3.5 (relaxed for cell reweighting):
//   FSR mass, pT > 7 GeV, |η| < 2.37 no crack, ΔR(γ,l) > 0.4,
//   ΔR(l,l) > 0.2, cluster quality, truth match (MC only).
//   No photon ID, no isolation.
//
// Reference: ATL-COM-PHYS-2021-640, ATL-COM-PHYS-2025-662
//
// Usage:
//   root -l -b -q 'derive_corrections.C("data.root","mc.root","corrections.root")'
//   root -l -b -q 'derive_corrections.C("data.root","mc.root","corrections.root",500000)'
///////////////////////////////////////////////////////////////////////////////

#include "config.h"

#include <TFile.h>
#include <TTree.h>
#include <TH2D.h>
#include <iostream>
#include <vector>
#include <cmath>

using namespace datamc;

// ======================================================================
// Accumulator for per-cell fraction statistics
// ======================================================================
struct CellStats {
    double sumF[kClusterSize][kNEtaBins];
    double sumF2[kClusterSize][kNEtaBins];
    Long64_t count[kNEtaBins];

    void reset() {
        for (int k = 0; k < kClusterSize; ++k)
            for (int n = 0; n < kNEtaBins; ++n) {
                sumF[k][n] = 0;
                sumF2[k][n] = 0;
            }
        for (int n = 0; n < kNEtaBins; ++n)
            count[n] = 0;
    }

    double mean(int k, int n) const {
        return count[n] > 0 ? sumF[k][n] / count[n] : 0;
    }

    double rms(int k, int n) const {
        if (count[n] < 2) return 0;
        double m = mean(k, n);
        double var = sumF2[k][n] / count[n] - m * m;
        return var > 0 ? std::sqrt(var) : 0;
    }
};

// ======================================================================
// Process one sample (data or MC)
// ======================================================================
void processSample(const char* filename, bool isMC,
                   CellStats& stats, Long64_t maxEvents) {
    stats.reset();

    TFile* f = TFile::Open(filename, "READ");
    if (!f || f->IsZombie()) {
        std::cerr << "ERROR: Cannot open " << filename << std::endl;
        return;
    }
    TTree* t = (TTree*)f->Get(kTreeName);
    if (!t) {
        std::cerr << "ERROR: No tree '" << kTreeName << "' in "
                  << filename << std::endl;
        f->Close(); delete f; return;
    }

    // Branch variables
    std::vector<double>* cellE = nullptr;
    Int_t cellSize = 0;
    Float_t eta2 = 0, photonPt = 0;
    Double_t mll = 0, mllg = 0;
    Double_t dR_l1_ph = 0, dR_l2_ph = 0;
    Double_t dR_ll = 0;
    Bool_t truthMatch = false;

    t->SetBranchStatus("*", 0);
    auto enable = [&](const char* name, void* addr) {
        if (t->GetBranch(name)) {
            t->SetBranchStatus(name, 1);
            t->SetBranchAddress(name, addr);
        } else {
            std::cerr << "WARNING: Branch '" << name
                      << "' not found in " << filename << std::endl;
        }
    };

    enable(kCellBranch, &cellE);
    enable(kCellSizeBranch, &cellSize);
    enable(kEtaBranch, &eta2);
    enable(kPhotonPtBranch, &photonPt);
    enable(kMllBranch, &mll);
    enable(kMllgBranch, &mllg);
    enable(kDRLepton1Branch, &dR_l1_ph);
    enable(kDRLepton2Branch, &dR_l2_ph);
    enable(kDRllBranch, &dR_ll);
    if (isMC) enable(kTruthMatchBranch, &truthMatch);

    Long64_t nEntries = t->GetEntries();
    if (maxEvents > 0 && maxEvents < nEntries) nEntries = maxEvents;

    std::cout << (isMC ? "MC" : "Data") << ": " << filename
              << " (" << nEntries << " entries)" << std::endl;

    Long64_t nUsed = 0;
    for (Long64_t i = 0; i < nEntries; ++i) {
        t->GetEntry(i);
        if (i > 0 && i % 2000000 == 0)
            std::cout << "  " << i << " / " << nEntries << std::endl;

        // Full selection (§3.5 relaxed for cell reweighting)
        if (!passSelection(photonPt, eta2, mll, mllg,
                           dR_l1_ph, dR_l2_ph, dR_ll,
                           cellSize, truthMatch, isMC))
            continue;

        if (!cellE || (int)cellE->size() != kClusterSize) continue;

        int etaBin = findEtaBin(std::fabs(eta2));
        if (etaBin < 0) continue;

        // Quality check: central cell must be hottest (use clamped copy)
        {
            std::vector<double> clamped(*cellE);
            clampCellEnergies(clamped);
            if (!isHealthyCluster(clamped)) continue;
        }

        // Compute fractions from RAW cells (no clamping) — this matches
        // the ATLAS shower shape branch computation.
        double Etot = 0;
        for (int k = 0; k < kClusterSize; ++k) Etot += cellE->at(k);
        if (Etot <= 0) continue;

        for (int k = 0; k < kClusterSize; ++k) {
            double frac = cellE->at(k) / Etot;
            stats.sumF[k][etaBin] += frac;
            stats.sumF2[k][etaBin] += frac * frac;
        }
        stats.count[etaBin]++;
        nUsed++;
    }

    std::cout << "  Selected: " << nUsed << " events" << std::endl;
    f->Close();
    delete f;
}

// ======================================================================
// Main
// ======================================================================
int derive_corrections(const char* dataFile,
                       const char* mcFile,
                       const char* outputFile,
                       Long64_t maxEvents = -1) {

    std::cout << "=== Deriving Data-MC Cell Corrections ===" << std::endl;

    CellStats dataStats, mcStats;
    processSample(dataFile, false, dataStats, maxEvents);
    processSample(mcFile,   true,  mcStats,   maxEvents);

    // ==================================================================
    // Write correction histograms
    // ==================================================================
    TFile* fout = TFile::Open(outputFile, "RECREATE");

    std::cout << "\n=== Correction Summary ===" << std::endl;
    std::cout << "EtaBin |    N_data     N_MC  |  Central shift  |  Central RMS_d/RMS_MC"
              << std::endl;
    std::cout << "-------|----------------------|-----------------|-----------------------"
              << std::endl;

    for (int n = 0; n < kNEtaBins; ++n) {
        TString suffix = Form("Eta_%1.2f_%1.2f",
                              kEtaLimits[n], kEtaLimits[n + 1]);

        // Method 1: flat shift
        TH2D* h_shift = new TH2D(
            "shift_" + suffix, "Flat shift (data-MC);phi;eta",
            kPhiSize, 0, kPhiSize, kEtaSize, 0, kEtaSize);

        // Method 2: mean / rms maps
        TH2D* h_meanMC = new TH2D(
            "meanMC_" + suffix, "Mean fraction (MC);phi;eta",
            kPhiSize, 0, kPhiSize, kEtaSize, 0, kEtaSize);
        TH2D* h_meanData = new TH2D(
            "meanData_" + suffix, "Mean fraction (Data);phi;eta",
            kPhiSize, 0, kPhiSize, kEtaSize, 0, kEtaSize);
        TH2D* h_rmsMC = new TH2D(
            "rmsMC_" + suffix, "RMS fraction (MC);phi;eta",
            kPhiSize, 0, kPhiSize, kEtaSize, 0, kEtaSize);
        TH2D* h_rmsData = new TH2D(
            "rmsData_" + suffix, "RMS fraction (Data);phi;eta",
            kPhiSize, 0, kPhiSize, kEtaSize, 0, kEtaSize);

        for (int k = 0; k < kClusterSize; ++k) {
            int phi_bin = k % kPhiSize;
            int eta_bin = k / kPhiSize;

            double mMC   = mcStats.mean(k, n);
            double mData = dataStats.mean(k, n);
            double rMC   = mcStats.rms(k, n);
            double rData = dataStats.rms(k, n);

            h_shift->SetBinContent(phi_bin + 1, eta_bin + 1, mData - mMC);
            h_meanMC->SetBinContent(phi_bin + 1, eta_bin + 1, mMC);
            h_meanData->SetBinContent(phi_bin + 1, eta_bin + 1, mData);
            h_rmsMC->SetBinContent(phi_bin + 1, eta_bin + 1, rMC);
            h_rmsData->SetBinContent(phi_bin + 1, eta_bin + 1, rData);
        }

        h_shift->Write();
        h_meanMC->Write();
        h_meanData->Write();
        h_rmsMC->Write();
        h_rmsData->Write();

        // Print central cell (index 38 = eta=3, phi=5 → bins 6,4)
        double cShift = h_shift->GetBinContent(6, 4);
        double rMC_c  = h_rmsMC->GetBinContent(6, 4);
        double rData_c = h_rmsData->GetBinContent(6, 4);
        double ratio = rMC_c > 0 ? rData_c / rMC_c : 0;

        std::cout << Form("%6d | %9lld %9lld  | %+14.6f  |  %.4f",
                          n, dataStats.count[n], mcStats.count[n],
                          cShift, ratio) << std::endl;
    }

    fout->Close();
    delete fout;

    std::cout << "\nCorrections written to: " << outputFile << std::endl;
    return 0;
}
